############################################################
# Core KernelSU + SUSFS fragment (minimal; heavy debug or  #
# logging lives in debug_enable.config)                    #
############################################################
CONFIG_KSU=y
# Leave CONFIG_KSU_DEBUG selection to debug/perf fragments
CONFIG_KSU_ALLOWLIST_WORKAROUND=n
CONFIG_KSU_LSM_SECURITY_HOOKS=y
CONFIG_KSU_WITH_KPROBES=y
CONFIG_KSU_SUSFS=y
CONFIG_KSU_SUSFS_HAS_MAGIC_MOUNT=y
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_SUS_KSU_DEFAULT_MOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_SUS_BIND_MOUNT=y
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_SUS_OVERLAYFS=y
CONFIG_KSU_SUSFS_TRY_UMOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_TRY_UMOUNT_FOR_BIND_MOUNT=y
CONFIG_KSU_SUSFS_SPOOF_UNAME=y
# Logging enabled only in debug fragment
CONFIG_KSU_SUSFS_HIDE_KSU_SUSFS_SYMBOLS=y
CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG=y
CONFIG_KSU_SUSFS_OPEN_REDIRECT=y
CONFIG_PID_NS=y
CONFIG_FHANDLE=y
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_KALLSYMS=y
# KALLSYMS_ALL only in debug build
CONFIG_KPROBES=y
CONFIG_IKCONFIG=y
CONFIG_SECURITYFS=y
# Minimal LSM list for performance build (debug fragment may expand)
CONFIG_LSM="yama,integrity,selinux,kernelsu"
