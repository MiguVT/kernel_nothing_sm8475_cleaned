#############################################
# Refined KernelSU-Next + SuSFS Configuration
# Device: Nothing Phone 2 (pong) / Meteoric Kernel
# Kernel: GKI-android12-5.10
# Build Modes: BASE (minimal), DEBUG (logging), PROD (optimized)
# Enhancements: Added SEPolicy and matrix hiding for better detection bypass
#############################################

# --- KernelSU Core ---
CONFIG_KSU=y
CONFIG_KSU_WITH_KPROBES=n

# --- SuSFS Integration ---
CONFIG_KSU_SUSFS=y
CONFIG_KSU_SUSFS_HAS_MAGIC_MOUNT=y

# Core SuSFS features
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_TRY_UMOUNT=y

# Advanced / optional (enhanced for hiding on Nothing Phone 2)
CONFIG_KSU_SUSFS_SPOOF_UNAME=y
CONFIG_KSU_SUSFS_SUS_SU=y
CONFIG_KSU_SUSFS_SPOOF_CMDLINE=y
CONFIG_KSU_SUSFS_HIDE_VENDOR_SEPOLICY=y  # Added for vendor SEPolicy spoofing
CONFIG_KSU_SUSFS_HIDE_COMPAT_MATRIX=y    # Added for compatibility matrix hiding

# Logging (disabled by default; enable for DEBUG build)
CONFIG_KSU_SUSFS_ENABLE_LOG=n

# --- LSM Ordering (with SELinux for Android compatibility and SuSFS SEPolicy support) ---
CONFIG_LSM="lockdown,yama,integrity,selinux,bpf"

# --- SELinux for Permissive Rooted Setup ---
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_DEVELOP=y

# --- GKI / Filesystem / Signing Requirements ---
CONFIG_MODVERSIONS=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=n
CONFIG_SYSTEM_TRUSTED_KEYS=""

#############################################
# End of Refined Config
#############################################
